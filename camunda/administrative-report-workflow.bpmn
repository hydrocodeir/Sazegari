<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_AdministrativeReport" targetNamespace="https://hydrocode.ir/sazegari/administrative-report" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="AdministrativeReportWorkflow" name="Administrative report BPM workflow" isExecutable="true">
    <bpmn:startEvent id="StartReportRequest" name="Report requested">
      <bpmn:outgoing>Flow_Start_ToDraft</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="CreateReportDraft" name="Create report draft">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="expert" />
        <zeebe:formDefinition formId="administrative-report-draft-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_ToDraft</bpmn:incoming>
      <bpmn:incoming>Flow_Revision_ToDraft</bpmn:incoming>
      <bpmn:outgoing>Flow_Draft_ToRouting</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="EvaluateRoutingRules" name="Evaluate routing rules">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="administrative_report_routing" resultVariable="routing" bindingType="deployment" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Draft_ToRouting</bpmn:incoming>
      <bpmn:outgoing>Flow_Routing_ToSupervisor</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="ReviewBySupervisor" name="Review by supervisor">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="supervisor" />
        <zeebe:formDefinition formId="administrative-report-review-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Routing_ToSupervisor</bpmn:incoming>
      <bpmn:outgoing>Flow_Supervisor_ToDecision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_SupervisorDecision" name="Supervisor decision" default="Flow_Supervisor_Return">
      <bpmn:incoming>Flow_Supervisor_ToDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Supervisor_Approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Supervisor_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Supervisor_Escalate</bpmn:outgoing>
      <bpmn:outgoing>Flow_Supervisor_Return</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="ReviewByDepartmentManager" name="Review by department manager">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="department_manager" />
        <zeebe:formDefinition formId="administrative-report-review-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Supervisor_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_Department_ToDecision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_DepartmentDecision" name="Department manager decision" default="Flow_Department_Return">
      <bpmn:incoming>Flow_Department_ToDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Department_Approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Department_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Department_Escalate</bpmn:outgoing>
      <bpmn:outgoing>Flow_Department_Return</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="ReviewBySeniorManager" name="Review by senior manager">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="senior_manager" />
        <zeebe:formDefinition formId="administrative-report-review-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Department_Approve</bpmn:incoming>
      <bpmn:incoming>Flow_Department_Escalate</bpmn:incoming>
      <bpmn:incoming>Flow_Supervisor_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_Senior_ToDecision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_SeniorDecision" name="Senior manager decision" default="Flow_Senior_Return">
      <bpmn:incoming>Flow_Senior_ToDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Senior_Finalize</bpmn:outgoing>
      <bpmn:outgoing>Flow_Senior_AdminOverride</bpmn:outgoing>
      <bpmn:outgoing>Flow_Senior_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Senior_Return</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="AdminOverrideReview" name="Admin override review">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="admin" />
        <zeebe:formDefinition formId="administrative-report-review-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Senior_AdminOverride</bpmn:incoming>
      <bpmn:outgoing>Flow_Admin_ToArchiveOfficer</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="ArchiveReport" name="Archive report">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="archive_officer" />
        <zeebe:formDefinition formId="administrative-report-archive-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Senior_Finalize</bpmn:incoming>
      <bpmn:incoming>Flow_Admin_ToArchiveOfficer</bpmn:incoming>
      <bpmn:outgoing>Flow_Archive_ToRecord</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="ReviseReport" name="Revise report">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="expert" />
        <zeebe:formDefinition formId="administrative-report-draft-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Supervisor_Return</bpmn:incoming>
      <bpmn:incoming>Flow_Department_Return</bpmn:incoming>
      <bpmn:incoming>Flow_Senior_Return</bpmn:incoming>
      <bpmn:outgoing>Flow_Revision_ToDraft</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="RecordArchive" name="Record archive">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="record-report-archive" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Archive_ToRecord</bpmn:incoming>
      <bpmn:outgoing>Flow_Record_ToArchivedEnd</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndArchived" name="Archived">
      <bpmn:incoming>Flow_Record_ToArchivedEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndRejected" name="Rejected">
      <bpmn:incoming>Flow_Supervisor_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_Department_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_Senior_Reject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_ToDraft" sourceRef="StartReportRequest" targetRef="CreateReportDraft" />
    <bpmn:sequenceFlow id="Flow_Draft_ToRouting" sourceRef="CreateReportDraft" targetRef="EvaluateRoutingRules" />
    <bpmn:sequenceFlow id="Flow_Routing_ToSupervisor" sourceRef="EvaluateRoutingRules" targetRef="ReviewBySupervisor" />
    <bpmn:sequenceFlow id="Flow_Supervisor_ToDecision" sourceRef="ReviewBySupervisor" targetRef="Gateway_SupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_Supervisor_Approve" name="approve" sourceRef="Gateway_SupervisorDecision" targetRef="ReviewByDepartmentManager">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "approve"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Supervisor_Reject" name="reject" sourceRef="Gateway_SupervisorDecision" targetRef="EndRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Supervisor_Escalate" name="escalate" sourceRef="Gateway_SupervisorDecision" targetRef="ReviewBySeniorManager">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "escalate" or routing.escalate = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Supervisor_Return" name="return" sourceRef="Gateway_SupervisorDecision" targetRef="ReviseReport" />
    <bpmn:sequenceFlow id="Flow_Department_ToDecision" sourceRef="ReviewByDepartmentManager" targetRef="Gateway_DepartmentDecision" />
    <bpmn:sequenceFlow id="Flow_Department_Approve" name="approve" sourceRef="Gateway_DepartmentDecision" targetRef="ReviewBySeniorManager">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "approve" or decision = "finalize"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Department_Reject" name="reject" sourceRef="Gateway_DepartmentDecision" targetRef="EndRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Department_Escalate" name="escalate" sourceRef="Gateway_DepartmentDecision" targetRef="ReviewBySeniorManager">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "escalate" or routing.escalate = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Department_Return" name="return" sourceRef="Gateway_DepartmentDecision" targetRef="ReviseReport" />
    <bpmn:sequenceFlow id="Flow_Senior_ToDecision" sourceRef="ReviewBySeniorManager" targetRef="Gateway_SeniorDecision" />
    <bpmn:sequenceFlow id="Flow_Senior_Finalize" name="finalize" sourceRef="Gateway_SeniorDecision" targetRef="ArchiveReport">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "finalize" or decision = "approve"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Senior_AdminOverride" name="admin override" sourceRef="Gateway_SeniorDecision" targetRef="AdminOverrideReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "adminOverride"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Senior_Reject" name="reject" sourceRef="Gateway_SeniorDecision" targetRef="EndRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Senior_Return" name="return" sourceRef="Gateway_SeniorDecision" targetRef="ReviseReport" />
    <bpmn:sequenceFlow id="Flow_Admin_ToArchiveOfficer" sourceRef="AdminOverrideReview" targetRef="ArchiveReport" />
    <bpmn:sequenceFlow id="Flow_Archive_ToRecord" sourceRef="ArchiveReport" targetRef="RecordArchive" />
    <bpmn:sequenceFlow id="Flow_Record_ToArchivedEnd" sourceRef="RecordArchive" targetRef="EndArchived" />
    <bpmn:sequenceFlow id="Flow_Revision_ToDraft" sourceRef="ReviseReport" targetRef="CreateReportDraft" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AdministrativeReport">
    <bpmndi:BPMNPlane id="BPMNPlane_AdministrativeReport" bpmnElement="AdministrativeReportWorkflow">
      <bpmndi:BPMNShape id="StartReportRequest_di" bpmnElement="StartReportRequest"><dc:Bounds x="152" y="202" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CreateReportDraft_di" bpmnElement="CreateReportDraft"><dc:Bounds x="240" y="180" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EvaluateRoutingRules_di" bpmnElement="EvaluateRoutingRules"><dc:Bounds x="390" y="180" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewBySupervisor_di" bpmnElement="ReviewBySupervisor"><dc:Bounds x="540" y="180" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SupervisorDecision_di" bpmnElement="Gateway_SupervisorDecision" isMarkerVisible="true"><dc:Bounds x="690" y="195" width="50" height="50" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewByDepartmentManager_di" bpmnElement="ReviewByDepartmentManager"><dc:Bounds x="790" y="180" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DepartmentDecision_di" bpmnElement="Gateway_DepartmentDecision" isMarkerVisible="true"><dc:Bounds x="940" y="195" width="50" height="50" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewBySeniorManager_di" bpmnElement="ReviewBySeniorManager"><dc:Bounds x="1040" y="180" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SeniorDecision_di" bpmnElement="Gateway_SeniorDecision" isMarkerVisible="true"><dc:Bounds x="1190" y="195" width="50" height="50" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdminOverrideReview_di" bpmnElement="AdminOverrideReview"><dc:Bounds x="1290" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ArchiveReport_di" bpmnElement="ArchiveReport"><dc:Bounds x="1440" y="180" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RecordArchive_di" bpmnElement="RecordArchive"><dc:Bounds x="1590" y="180" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndArchived_di" bpmnElement="EndArchived"><dc:Bounds x="1742" y="202" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviseReport_di" bpmnElement="ReviseReport"><dc:Bounds x="790" y="330" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected"><dc:Bounds x="1197" y="352" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_ToDraft_di" bpmnElement="Flow_Start_ToDraft"><di:waypoint x="188" y="220" /><di:waypoint x="240" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Draft_ToRouting_di" bpmnElement="Flow_Draft_ToRouting"><di:waypoint x="340" y="220" /><di:waypoint x="390" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Routing_ToSupervisor_di" bpmnElement="Flow_Routing_ToSupervisor"><di:waypoint x="490" y="220" /><di:waypoint x="540" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Supervisor_ToDecision_di" bpmnElement="Flow_Supervisor_ToDecision"><di:waypoint x="640" y="220" /><di:waypoint x="690" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Supervisor_Approve_di" bpmnElement="Flow_Supervisor_Approve"><di:waypoint x="740" y="220" /><di:waypoint x="790" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Supervisor_Reject_di" bpmnElement="Flow_Supervisor_Reject"><di:waypoint x="715" y="245" /><di:waypoint x="715" y="370" /><di:waypoint x="1197" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Supervisor_Escalate_di" bpmnElement="Flow_Supervisor_Escalate"><di:waypoint x="715" y="195" /><di:waypoint x="715" y="120" /><di:waypoint x="1090" y="120" /><di:waypoint x="1090" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Supervisor_Return_di" bpmnElement="Flow_Supervisor_Return"><di:waypoint x="715" y="245" /><di:waypoint x="715" y="370" /><di:waypoint x="790" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Department_ToDecision_di" bpmnElement="Flow_Department_ToDecision"><di:waypoint x="890" y="220" /><di:waypoint x="940" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Department_Approve_di" bpmnElement="Flow_Department_Approve"><di:waypoint x="990" y="220" /><di:waypoint x="1040" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Department_Reject_di" bpmnElement="Flow_Department_Reject"><di:waypoint x="965" y="245" /><di:waypoint x="965" y="370" /><di:waypoint x="1197" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Department_Escalate_di" bpmnElement="Flow_Department_Escalate"><di:waypoint x="990" y="220" /><di:waypoint x="1040" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Department_Return_di" bpmnElement="Flow_Department_Return"><di:waypoint x="965" y="245" /><di:waypoint x="965" y="370" /><di:waypoint x="890" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Senior_ToDecision_di" bpmnElement="Flow_Senior_ToDecision"><di:waypoint x="1140" y="220" /><di:waypoint x="1190" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Senior_Finalize_di" bpmnElement="Flow_Senior_Finalize"><di:waypoint x="1240" y="220" /><di:waypoint x="1440" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Senior_AdminOverride_di" bpmnElement="Flow_Senior_AdminOverride"><di:waypoint x="1215" y="195" /><di:waypoint x="1215" y="100" /><di:waypoint x="1290" y="100" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Senior_Reject_di" bpmnElement="Flow_Senior_Reject"><di:waypoint x="1215" y="245" /><di:waypoint x="1215" y="352" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Senior_Return_di" bpmnElement="Flow_Senior_Return"><di:waypoint x="1215" y="245" /><di:waypoint x="1215" y="370" /><di:waypoint x="890" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Admin_ToArchiveOfficer_di" bpmnElement="Flow_Admin_ToArchiveOfficer"><di:waypoint x="1390" y="100" /><di:waypoint x="1490" y="100" /><di:waypoint x="1490" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Archive_ToRecord_di" bpmnElement="Flow_Archive_ToRecord"><di:waypoint x="1540" y="220" /><di:waypoint x="1590" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Record_ToArchivedEnd_di" bpmnElement="Flow_Record_ToArchivedEnd"><di:waypoint x="1690" y="220" /><di:waypoint x="1742" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Revision_ToDraft_di" bpmnElement="Flow_Revision_ToDraft"><di:waypoint x="790" y="370" /><di:waypoint x="290" y="370" /><di:waypoint x="290" y="260" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
